<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daily Quest & Reward Tracker</title>
    <!-- Tailwind CSS for modern responsive styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Quicksand:wght@500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Quicksand', sans-serif;
            background-color: #f0f4f8;
        }
        h1, h2, h3, .font-display {
            font-family: 'Fredoka One', cursive;
        }
        .task-card {
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .task-card:active {
            transform: scale(0.98);
        }
        @keyframes pulse-neon {
            0%, 100% {
                box-shadow: 0 0 15px rgba(168, 85, 247, 0.6), 0 0 30px rgba(168, 85, 247, 0.4);
                transform: scale(1);
            }
            50% {
                box-shadow: 0 0 25px rgba(168, 85, 247, 0.9), 0 0 50px rgba(168, 85, 247, 0.6);
                transform: scale(1.03);
            }
        }
        .unlocked-glow {
            animation: pulse-neon 2s infinite ease-in-out;
        }
    </style>
</head>
<body class="min-h-screen py-6 px-4 sm:px-6 lg:px-8 text-slate-800 flex flex-col justify-between">

    <div class="max-w-md mx-auto w-full bg-white rounded-3xl shadow-xl overflow-hidden border-4 border-slate-100 flex-grow flex flex-col">
        
        <!-- Header Banner -->
        <div id="header-banner" class="bg-gradient-to-r from-indigo-500 to-purple-600 p-6 text-white text-center relative overflow-hidden shrink-0 transition-all duration-500">
            <div class="absolute -top-10 -left-10 w-32 h-32 bg-white/10 rounded-full"></div>
            <div class="absolute -bottom-10 -right-10 w-36 h-36 bg-white/10 rounded-full"></div>
            
            <div class="relative z-10">
                <span id="header-tag" class="bg-purple-700/50 text-purple-100 px-3 py-1 rounded-full text-xs uppercase tracking-wider font-bold">The Daily Quest</span>
                <h1 id="current-date" class="text-2xl mt-1 tracking-wide">Daily Adventures</h1>
                
                <!-- Streak Tracker -->
                <div class="flex items-center justify-center mt-3 space-x-1">
                    <span id="streak-emoji" class="text-xl font-display">🔥</span>
                    <span class="text-sm font-bold">Current Streak: <span id="streak-count" class="text-yellow-300 font-display text-lg">0</span> Days</span>
                </div>
            </div>
        </div>

        <!-- Interactive Video Game Time Bank -->
        <div class="p-6 bg-gradient-to-br from-amber-50 to-orange-50 border-b border-amber-100 shrink-0">
            <div class="flex items-center justify-between">
                <div>
                    <span class="text-xs font-bold text-amber-700 uppercase tracking-wider block">Banked Game Time</span>
                    <span id="bank-balance-display" class="text-2xl font-display text-amber-800">0 minutes</span>
                </div>
                <button id="spend-toggle-btn" class="px-4 py-2 bg-amber-500 hover:bg-amber-600 text-white text-xs font-display rounded-xl transition-all shadow-md transform active:scale-95">
                    Log Played Time
                </button>
            </div>
            
            <!-- Deduct Time Drawer -->
            <div id="spend-drawer" class="mt-4 pt-4 border-t border-amber-200/60 hidden transition-all duration-300">
                <p class="text-xs text-amber-800 font-bold mb-2">How many minutes of play time did you just use?</p>
                <div class="flex items-center space-x-2">
                    <input type="number" id="spend-amount-input" placeholder="e.g. 30" class="w-full px-3 py-2 text-sm border-2 border-amber-200 focus:border-amber-500 focus:outline-none rounded-xl" min="1" max="1440">
                    <button id="confirm-spend-btn" class="px-4 py-2 bg-amber-700 hover:bg-amber-800 text-white text-xs font-display rounded-xl transition-all shrink-0">
                        Spend
                    </button>
                </div>
                <p id="spend-error-msg" class="text-rose-500 text-[10px] mt-1 font-bold hidden"></p>
            </div>
        </div>

        <!-- Progress Tracker -->
        <div class="p-6 bg-slate-50 border-b border-slate-100 shrink-0">
            <div class="flex justify-between items-center mb-2">
                <span id="progress-label" class="text-sm font-bold text-slate-500 uppercase tracking-wider">Quest Progress</span>
                <span id="progress-percentage" class="text-lg font-display text-indigo-600">0%</span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-4 overflow-hidden p-0.5">
                <div id="progress-bar" class="bg-gradient-to-r from-indigo-500 to-purple-500 h-3 rounded-full transition-all duration-500 ease-out w-0"></div>
            </div>
        </div>

        <!-- Instructions Guidance -->
        <div class="px-6 pt-4 text-center text-xs text-slate-400">
            Tap a card once for a <span class="text-emerald-600 font-bold">Check (Success)</span>, twice for an <span class="text-rose-600 font-bold">X (Failure)</span>, and thrice to reset.
        </div>

        <!-- Main Task List Container -->
        <div class="p-6 space-y-4 overflow-y-auto flex-grow" id="checklist-container">
            <!-- Dynamic checklist items will be inserted here by JavaScript -->
        </div>

        <!-- Reward Panel -->
        <div class="p-6 bg-slate-50 border-t border-slate-100 shrink-0">
            <div id="reward-panel" class="bg-slate-200 text-slate-500 rounded-2xl p-5 text-center transition-all duration-500 flex flex-col items-center justify-center relative overflow-hidden">
                
                <!-- Confetti Canvas -->
                <canvas id="confetti-canvas" class="absolute inset-0 pointer-events-none w-full h-full hidden"></canvas>

                <!-- Icon Container -->
                <div id="reward-icon-container" class="w-16 h-16 bg-slate-300 rounded-full flex items-center justify-center mb-3 text-3xl transition-transform duration-500">
                    🔒
                </div>

                <h3 id="reward-title" class="text-lg font-display mb-1 transition-colors duration-500">Video Game Session</h3>
                <p id="reward-description" class="text-xs max-w-xs transition-colors duration-500">
                    Complete all daily tasks to unlock your screen time credentials for this evening.
                </p>

                <!-- Claim Button -->
                <button id="claim-button" class="mt-4 px-6 py-2.5 bg-gradient-to-r from-yellow-400 to-amber-500 text-white font-display rounded-xl shadow-md hover:from-yellow-500 hover:to-amber-600 transform active:scale-95 transition-all hidden">
                    Complete Day & Save Streak!
                </button>
            </div>

            <!-- Parent Reset Control -->
            <div class="mt-4 flex justify-between items-center text-xs text-slate-400 px-1">
                <span>All progress will reset daily.</span>
                <button id="reset-button" class="hover:text-slate-600 flex items-center space-x-1 transition-colors">
                    <span>🔄 Reset List</span>
                </button>
            </div>
        </div>

    </div>

    <!-- Custom Confirmation Modal -->
    <div id="reset-modal" class="fixed inset-0 bg-slate-950/50 backdrop-blur-sm z-50 flex items-center justify-center hidden">
        <div class="bg-white p-6 rounded-3xl max-w-xs w-full mx-4 shadow-2xl text-center border-2 border-slate-100">
            <h3 class="font-display text-lg text-slate-900 mb-2">Are you sure?</h3>
            <p class="text-xs text-slate-500 mb-6 leading-relaxed">This action will reset the checkboxes. If a failure is currently active, it will also reset the streak.</p>
            <div class="flex space-x-3">
                <button id="cancel-reset" class="flex-1 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-xl text-sm font-bold transition-colors">
                    Cancel
                </button>
                <button id="confirm-reset" class="flex-1 py-2.5 bg-rose-500 hover:bg-rose-600 text-white rounded-xl text-sm font-bold transition-colors">
                    Reset
                </button>
            </div>
        </div>
    </div>

    <!-- Footnote for subtle parenting humor -->
    <div class="text-center text-xs text-slate-400 mt-4 max-w-md mx-auto">
        Remember: One slip-up turns the entire day into a historic lesson on consequences. No pressure.
    </div>

    <script>
        // Default task list. States: "none", "checked", "failed"
        const defaultTasks = [
            {
                id: "meta-effort",
                title: "Complete the List of the Previous Day",
                desc: "You must dedicate a reasonable amount of effort to finish whatever you left incomplete. The turning of the calendar page does not grant amnesty for unfinished business.",
                state: "none"
            },
            {
                id: "hygiene-teeth",
                title: "Brush Your Teeth",
                desc: "You must use actual toothpaste and cover all surfaces. Swishing water around for three seconds is not brush work.",
                state: "none"
            },
            {
                id: "hygiene-face",
                title: "Wash Your Face",
                desc: "Cleanse with real water and soap. The sleeve of your sweatshirt is not a designated facial towel.",
                state: "none"
            },
            {
                id: "hygiene-clothes",
                title: "Get Fully Dressed",
                desc: "Pajamas do not count as daytime attire. Put on clean, actual clothes suitable for public eyes.",
                state: "none"
            },
            {
                id: "academics",
                title: "Complete Homeschool Work",
                desc: "Acquire knowledge with focus. The math problems are more afraid of you than you are of them.",
                state: "none"
            },
            {
                id: "mindfulness",
                title: "Listen to Guided Meditation",
                desc: "Sit still and follow the breathing. Thinking about video games is permitted, but you must keep your eyes closed.",
                state: "none"
            },
            {
                id: "chores-room",
                title: "Clean Your Room",
                desc: "The floor must be visible. Shoving everything under your bed is a temporary structural hazard, not cleaning.",
                state: "none"
            },
            {
                id: "chores-dishes",
                title: "Wash and/or Unload Dishes",
                desc: "The kitchen sink is not a permanent storage facility for dirty plates. You must scrub the pans or empty the dishwasher. Placing a singular fork on a shelf does not count as unloading.",
                state: "none"
            },
            {
                id: "social-mommy",
                title: "Be Respectful to Mommy",
                desc: "Listen carefully, follow directions the first time they are given, and speak with a polite tone. Mommy is the chief executive officer of this establishment.",
                state: "none"
            },
            {
                id: "social-kindness",
                title: "Be Kind to Your sister",
                desc: "Speak with encouraging words. Sarcasm is an advanced art form that is best saved for your adult years.",
                state: "none"
            },
            {
                id: "social-play",
                title: "Play with Your sister",
                desc: "Spend a reasonable amount of continuous time playing together. Resolving disputes without physical leverage is highly encouraged.",
                state: "none"
            },
            {
                id: "social-frankie",
                title: "Play with Frankie",
                desc: "Spend quality time interacting with Frankie. Throwing a toy once and then returning to your own thoughts does not count as playing.",
                state: "none"
            },
            {
                id: "emotions",
                title: "Keep Your Emotions Under Control",
                desc: "When frustration strikes, take deep breaths. Screaming at a stubborn building block is not a viable strategy.",
                state: "none"
            }
        ];

        let tasks = [];
        let currentStreak = 0;
        let bankedMinutes = 0;
        let confettiAnimationId = null;

        function init() {
            const options = { weekday: 'long', month: 'short', day: 'numeric' };
            document.getElementById('current-date').textContent = new Date().toLocaleDateString('en-US', options);

            // Load Streak
            const savedStreak = localStorage.getItem('homeschool_quest_streak_girl');
            currentStreak = savedStreak ? parseInt(savedStreak, 10) : 0;

            // Load Banked Minutes
            const savedBank = localStorage.getItem('homeschool_quest_banked_minutes_girl');
            bankedMinutes = savedBank ? parseInt(savedBank, 10) : 0;
            updateBankDisplay();

            const lastClaimDate = localStorage.getItem('homeschool_quest_last_claim_date_girl');
            const todayStr = new Date().toDateString();

            if (lastClaimDate) {
                const lastClaim = new Date(lastClaimDate);
                const today = new Date(todayStr);
                lastClaim.setHours(0,0,0,0);
                today.setHours(0,0,0,0);
                
                const timeDiff = today.getTime() - lastClaim.getTime();
                const dayDiff = Math.floor(timeDiff / (1000 * 60 * 60 * 24));
                
                if (dayDiff > 1) {
                    currentStreak = 0;
                    localStorage.setItem('homeschool_quest_streak_girl', 0);
                }
            }
            updateStreakDisplay();

            const savedTasks = localStorage.getItem('homeschool_quest_tasks_girl');
            const lastSavedDate = localStorage.getItem('homeschool_quest_date_girl');

            if (savedTasks && lastSavedDate === todayStr) {
                tasks = JSON.parse(savedTasks);
                tasks.forEach(t => {
                    if (t.state === undefined) {
                        t.state = t.checked ? "checked" : "none";
                        delete t.checked;
                    }
                });
            } else {
                tasks = JSON.parse(JSON.stringify(defaultTasks));
                localStorage.setItem('homeschool_quest_date_girl', todayStr);
                saveTasksToStorage();
            }

            renderTasks();
            updateProgress();
        }

        function renderTasks() {
            const container = document.getElementById('checklist-container');
            container.innerHTML = '';

            const lastClaimDate = localStorage.getItem('homeschool_quest_last_claim_date_girl');
            const todayStr = new Date().toDateString();
            const alreadyClaimedToday = (lastClaimDate === todayStr);

            tasks.forEach((task, index) => {
                const card = document.createElement('div');
                
                let cardClass = "task-card flex items-start space-x-4 p-4 rounded-2xl border-2 transition-all duration-200 ";
                if (!alreadyClaimedToday) {
                    cardClass += "cursor-pointer ";
                } else {
                    cardClass += "cursor-default opacity-80 ";
                }

                let iconContent = "";
                let iconClass = "w-7 h-7 rounded-lg border-2 flex items-center justify-center transition-all duration-200 shrink-0 ";
                let textClass = "font-bold text-base transition-colors ";

                if (task.state === "checked") {
                    cardClass += "bg-emerald-50/70 border-emerald-200 shadow-sm";
                    iconClass += "bg-emerald-500 border-emerald-500 text-white scale-110";
                    textClass += "text-slate-500 line-through";
                    iconContent = `
                        <svg class="w-5 h-5 stroke-current stroke-[3]" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                    `;
                } else if (task.state === "failed") {
                    cardClass += "bg-rose-50/70 border-rose-200 shadow-sm";
                    iconClass += "bg-rose-500 border-rose-500 text-white scale-110";
                    textClass += "text-rose-900";
                    iconContent = `
                        <svg class="w-5 h-5 stroke-current stroke-[3]" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    `;
                } else {
                    cardClass += "bg-white border-slate-100";
                    if (!alreadyClaimedToday) {
                        cardClass += " hover:border-indigo-100 hover:shadow-md";
                    }
                    iconClass += "border-slate-300 bg-white";
                    textClass += "text-slate-800";
                }

                card.className = cardClass;
                
                if (!alreadyClaimedToday) {
                    card.onclick = () => toggleTaskState(index);
                }

                card.innerHTML = `
                    <div class="flex items-center justify-center mt-1 shrink-0">
                        <div class="${iconClass}">
                            ${iconContent}
                        </div>
                    </div>
                    <div class="flex-grow">
                        <h4 class="${textClass}">
                            ${task.title}
                        </h4>
                        <p class="text-xs text-slate-500 mt-1 leading-relaxed">
                            ${task.desc}
                        </p>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        function toggleTaskState(index) {
            const currentState = tasks[index].state;
            if (currentState === "none" || currentState === undefined) {
                tasks[index].state = "checked";
                playAudioTone('check');
            } else if (currentState === "checked") {
                tasks[index].state = "failed";
                playAudioTone('fail');
            } else {
                tasks[index].state = "none";
                playAudioTone('uncheck');
            }

            saveTasksToStorage();
            renderTasks();
            updateProgress();
        }

        function saveTasksToStorage() {
            localStorage.setItem('homeschool_quest_tasks_girl', JSON.stringify(tasks));
        }

        function updateProgress() {
            const hasFailure = tasks.some(t => t.state === "failed");
            const completedCount = tasks.filter(t => t.state === "checked").length;
            const totalCount = tasks.length;
            
            const lastClaimDate = localStorage.getItem('homeschool_quest_last_claim_date_girl');
            const todayStr = new Date().toDateString();
            const alreadyClaimedToday = (lastClaimDate === todayStr);

            const percentage = hasFailure ? 0 : (totalCount > 0 ? Math.round((completedCount / totalCount) * 100) : 0);

            const progressPercentageElement = document.getElementById('progress-percentage');
            if (alreadyClaimedToday) {
                progressPercentageElement.textContent = "COMPLETE";
            } else {
                progressPercentageElement.textContent = hasFailure ? "FAILED" : `${percentage}%`;
            }
            
            const progressBar = document.getElementById('progress-bar');
            const headerBanner = document.getElementById('header-banner');
            const headerTag = document.getElementById('header-tag');
            const streakEmoji = document.getElementById('streak-emoji');

            if (hasFailure) {
                progressBar.style.width = `0%`;
                progressBar.className = "bg-rose-500 h-3 rounded-full transition-all duration-500 ease-out";
                
                headerBanner.className = "bg-gradient-to-r from-slate-700 to-rose-950 p-6 text-white text-center relative overflow-hidden shrink-0 transition-all duration-500";
                headerTag.textContent = "Quest Voided";
                headerTag.className = "bg-rose-900/60 text-rose-100 px-3 py-1 rounded-full text-xs uppercase tracking-wider font-bold";
                streakEmoji.textContent = "📉";

                if (currentStreak > 0) {
                    currentStreak = 0;
                    localStorage.setItem('homeschool_quest_streak_girl', 0);
                    updateStreakDisplay();
                }
            } else {
                progressBar.style.width = alreadyClaimedToday ? "100%" : `${percentage}%`;
                progressBar.className = "bg-gradient-to-r from-indigo-500 to-purple-500 h-3 rounded-full transition-all duration-500 ease-out";
                
                headerBanner.className = "bg-gradient-to-r from-indigo-500 to-purple-600 p-6 text-white text-center relative overflow-hidden shrink-0 transition-all duration-500";
                headerTag.textContent = "The Daily Quest";
                headerTag.className = "bg-purple-700/50 text-purple-100 px-3 py-1 rounded-full text-xs uppercase tracking-wider font-bold";
                streakEmoji.textContent = "🔥";
            }

            const rewardPanel = document.getElementById('reward-panel');
            const rewardIcon = document.getElementById('reward-icon-container');
            const rewardTitle = document.getElementById('reward-title');
            const rewardDesc = document.getElementById('reward-description');
            const claimButton = document.getElementById('claim-button');

            if (alreadyClaimedToday) {
                stopConfetti();
                rewardPanel.className = "bg-gradient-to-br from-purple-600 via-indigo-600 to-indigo-700 text-white rounded-2xl p-5 text-center transition-all duration-500 flex flex-col items-center justify-center relative overflow-hidden unlocked-glow";
                rewardIcon.className = "w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mb-3 text-4xl scale-110 transition-transform duration-500";
                rewardIcon.innerHTML = "🎮";
                rewardTitle.textContent = "Quest Completed For Today!";
                rewardDesc.textContent = "The video game reward has been unlocked and recorded. Gia earned 45 minutes of screen time.";
                claimButton.className = "mt-4 px-6 py-2.5 bg-slate-400 text-slate-200 font-display rounded-xl shadow-md cursor-not-allowed w-full";
                claimButton.textContent = "Reward Already Claimed!";
                claimButton.disabled = true;
                claimButton.classList.remove('hidden');
            } else if (hasFailure) {
                stopConfetti();
                rewardPanel.className = "bg-rose-100 text-rose-900 rounded-2xl p-5 text-center transition-all duration-500 flex flex-col items-center justify-center relative overflow-hidden border border-rose-300";
                rewardIcon.className = "w-16 h-16 bg-rose-200 rounded-full flex items-center justify-center mb-3 text-3xl transition-transform duration-500";
                rewardIcon.innerHTML = "🚫";
                rewardTitle.textContent = "Access Denied";
                rewardDesc.textContent = "An item was marked with a failure. Video game access is unavailable for this evening.";
                claimButton.classList.add('hidden');
                claimButton.disabled = false;
            } else if (percentage === 100) {
                if (!rewardPanel.classList.contains('unlocked-glow')) {
                    playAudioTone('unlock');
                    startConfetti();
                }
                rewardPanel.className = "bg-gradient-to-br from-purple-600 via-indigo-600 to-indigo-700 text-white rounded-2xl p-5 text-center transition-all duration-500 flex flex-col items-center justify-center relative overflow-hidden unlocked-glow";
                rewardIcon.className = "w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mb-3 text-4xl scale-110 transition-transform duration-500";
                rewardIcon.innerHTML = "🎮";
                rewardTitle.textContent = "Video Game Session Unlocked!";
                rewardDesc.textContent = "You have completed all objectives perfectly. You will earn 45 minutes of game time upon saving!";
                claimButton.className = "mt-4 px-6 py-2.5 bg-gradient-to-r from-yellow-400 to-amber-500 text-white font-display rounded-xl shadow-md hover:from-yellow-500 hover:to-amber-600 transform active:scale-95 transition-all w-full";
                claimButton.textContent = "Complete Day & Earn +45 Min!";
                claimButton.disabled = false;
                claimButton.classList.remove('hidden');
            } else {
                stopConfetti();
                rewardPanel.className = "bg-slate-200 text-slate-500 rounded-2xl p-5 text-center transition-all duration-500 flex flex-col items-center justify-center relative overflow-hidden";
                rewardIcon.className = "w-16 h-16 bg-slate-300 rounded-full flex items-center justify-center mb-3 text-3xl transition-transform duration-500";
                rewardIcon.innerHTML = "🔒";
                rewardTitle.textContent = "Video Game Session";
                rewardDesc.textContent = "Complete all daily tasks to unlock your screen time credentials and bank 45 minutes.";
                claimButton.classList.add('hidden');
                claimButton.disabled = false;
            }
        }

        function playAudioTone(type) {
            try {
                const AudioContext = window.AudioContext || window.webkitAudioContext;
                if (!AudioContext) return;
                const ctx = new AudioContext();
                const now = ctx.currentTime;
                
                if (type === 'check') {
                    const osc = ctx.createOscillator();
                    const gain = ctx.createGain();
                    osc.connect(gain);
                    gain.connect(ctx.destination);
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(440, now);
                    osc.frequency.exponentialRampToValueAtTime(880, now + 0.12);
                    gain.gain.setValueAtTime(0.08, now);
                    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.12);
                    osc.start();
                    osc.stop(now + 0.12);
                } else if (type === 'uncheck') {
                    const osc = ctx.createOscillator();
                    const gain = ctx.createGain();
                    osc.connect(gain);
                    gain.connect(ctx.destination);
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(300, now);
                    osc.frequency.exponentialRampToValueAtTime(150, now + 0.08);
                    gain.gain.setValueAtTime(0.08, now);
                    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.08);
                    osc.start();
                    osc.stop(now + 0.08);
                } else if (type === 'fail') {
                    const osc1 = ctx.createOscillator();
                    const osc2 = ctx.createOscillator();
                    const gain = ctx.createGain();
                    osc1.connect(gain);
                    osc2.connect(gain);
                    gain.connect(ctx.destination);
                    
                    osc1.type = 'sawtooth';
                    osc2.type = 'sawtooth';
                    osc1.frequency.setValueAtTime(180, now);
                    osc2.frequency.setValueAtTime(177, now);
                    osc1.frequency.linearRampToValueAtTime(120, now + 0.25);
                    osc2.frequency.linearRampToValueAtTime(117, now + 0.25);
                    
                    gain.gain.setValueAtTime(0.1, now);
                    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.25);
                    
                    osc1.start();
                    osc2.start();
                    osc1.stop(now + 0.25);
                    osc2.stop(now + 0.25);
                } else if (type === 'unlock') {
                    const playNote = (freq, start, duration) => {
                        const osc = ctx.createOscillator();
                        const gain = ctx.createGain();
                        osc.connect(gain);
                        gain.connect(ctx.destination);
                        osc.type = 'triangle';
                        osc.frequency.setValueAtTime(freq, start);
                        gain.gain.setValueAtTime(0.12, start);
                        gain.gain.exponentialRampToValueAtTime(0.001, start + duration);
                        osc.start(start);
                        osc.stop(start + duration);
                    };
                    playNote(261.63, now, 0.1);       
                    playNote(329.63, now + 0.08, 0.1);  
                    playNote(392.00, now + 0.16, 0.1);  
                    playNote(523.25, now + 0.24, 0.4);  
                }
            } catch (err) {}
        }

        function updateStreakDisplay() {
            document.getElementById('streak-count').textContent = currentStreak;
        }

        // Updates screen displays for the Time Bank balance
        function updateBankDisplay() {
            const display = document.getElementById('bank-balance-display');
            if (bankedMinutes === 0) {
                display.textContent = "0 minutes";
            } else {
                const hours = Math.floor(bankedMinutes / 60);
                const mins = bankedMinutes % 60;
                if (hours > 0) {
                    display.textContent = `${hours}h ${mins}m`;
                } else {
                    display.textContent = `${mins} minutes`;
                }
            }
        }

        function startConfetti() {
            const canvas = document.getElementById('confetti-canvas');
            canvas.classList.remove('hidden');
            const ctx = canvas.getContext('2d');
            
            let width = canvas.width = canvas.parentElement.clientWidth;
            let height = canvas.height = canvas.parentElement.clientHeight;

            window.addEventListener('resize', () => {
                if (canvas) {
                    width = canvas.width = canvas.parentElement?.clientWidth || width;
                    height = canvas.height = canvas.parentElement?.clientHeight || height;
                }
            });

            const colors = ['#f43f5e', '#3b82f6', '#10b981', '#eab308', '#a855f7', '#ff7849'];
            const particles = [];

            for (let i = 0; i < 50; i++) {
                particles.push({
                    x: Math.random() * width,
                    y: Math.random() * -height - 20,
                    size: Math.random() * 6 + 4,
                    color: colors[Math.floor(Math.random() * colors.length)],
                    speedY: Math.random() * 2 + 1,
                    speedX: Math.random() * 2 - 1,
                    rotation: Math.random() * 360,
                    rotationSpeed: Math.random() * 4 - 2
                });
            }

            function animate() {
                ctx.clearRect(0, 0, width, height);
                particles.forEach(p => {
                    p.y += p.speedY;
                    p.x += p.speedX;
                    p.rotation += p.rotationSpeed;

                    ctx.save();
                    ctx.translate(p.x, p.y);
                    ctx.rotate(p.rotation * Math.PI / 180);
                    ctx.fillStyle = p.color;
                    ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size);
                    ctx.restore();

                    if (p.y > height) {
                        p.y = -10;
                        p.x = Math.random() * width;
                    }
                });
                confettiAnimationId = requestAnimationFrame(animate);
            }
            animate();
        }

        function stopConfetti() {
            if (confettiAnimationId) {
                cancelAnimationFrame(confettiAnimationId);
                confettiAnimationId = null;
            }
            const canvas = document.getElementById('confetti-canvas');
            if (canvas) {
                canvas.classList.add('hidden');
                const ctx = canvas.getContext('2d');
                ctx.clearRect(0, 0, canvas.width, canvas.height);
            }
        }

        // Setup Custom Reset Modal
        const resetModal = document.getElementById('reset-modal');
        const showResetModal = () => resetModal.classList.remove('hidden');
        const hideResetModal = () => resetModal.classList.add('hidden');

        document.getElementById('reset-button').addEventListener('click', showResetModal);
        document.getElementById('cancel-reset').addEventListener('click', hideResetModal);
        
        document.getElementById('confirm-reset').addEventListener('click', () => {
            const hasFailure = tasks.some(t => t.state === "failed");
            
            tasks = JSON.parse(JSON.stringify(defaultTasks));
            saveTasksToStorage();
            
            if (hasFailure) {
                currentStreak = 0;
                localStorage.setItem('homeschool_quest_streak_girl', 0);
                updateStreakDisplay();
            }

            renderTasks();
            updateProgress();
            hideResetModal();
        });

        // Time Bank Interaction Drawer Toggle
        const spendDrawer = document.getElementById('spend-drawer');
        const spendInput = document.getElementById('spend-amount-input');
        const spendErrorMsg = document.getElementById('spend-error-msg');
        
        document.getElementById('spend-toggle-btn').addEventListener('click', () => {
            spendDrawer.classList.toggle('hidden');
            spendErrorMsg.classList.add('hidden');
            spendInput.value = '';
        });

        // Deduct Game Time Button logic
        document.getElementById('confirm-spend-btn').addEventListener('click', () => {
            const amount = parseInt(spendInput.value, 10);
            spendErrorMsg.classList.add('hidden');

            if (isNaN(amount) || amount <= 0) {
                spendErrorMsg.textContent = "Please enter a valid positive number of minutes.";
                spendErrorMsg.classList.remove('hidden');
                return;
            }

            if (amount > bankedMinutes) {
                spendErrorMsg.textContent = `You only have ${bankedMinutes} banked minutes remaining. You cannot spend more than you have!`;
                spendErrorMsg.classList.remove('hidden');
                return;
            }

            bankedMinutes -= amount;
            localStorage.setItem('homeschool_quest_banked_minutes_girl', bankedMinutes);
            updateBankDisplay();
            playAudioTone('uncheck');

            spendDrawer.classList.add('hidden');
            spendInput.value = '';

            // Brief success popup banner
            const banner = document.createElement('div');
            banner.className = "fixed top-6 left-1/2 transform -translate-x-1/2 bg-slate-900 text-white px-6 py-3 rounded-full text-sm font-bold shadow-2xl z-50 transition-all duration-300 ease-out";
            banner.textContent = `Logged: spent ${amount} minutes. Balance updated!`;
            document.body.appendChild(banner);
            
            setTimeout(() => {
                banner.classList.add('opacity-0');
                setTimeout(() => banner.remove(), 300);
            }, 3000);
        });

        // Complete Day Claim Button logic
        document.getElementById('claim-button').addEventListener('click', () => {
            const todayStr = new Date().toDateString();
            const lastClaimDate = localStorage.getItem('homeschool_quest_last_claim_date_girl');

            if (lastClaimDate === todayStr) {
                return;
            }

            // Record Streak
            currentStreak += 1;
            localStorage.setItem('homeschool_quest_streak_girl', currentStreak);
            localStorage.setItem('homeschool_quest_last_claim_date_girl', todayStr);
            updateStreakDisplay();
            
            // Add 45 minutes to the Time Bank!
            bankedMinutes += 45;
            localStorage.setItem('homeschool_quest_banked_minutes_girl', bankedMinutes);
            updateBankDisplay();

            playAudioTone('unlock');
            
            renderTasks();
            updateProgress();

            const banner = document.createElement('div');
            banner.className = "fixed top-6 left-1/2 transform -translate-x-1/2 bg-slate-900 text-white px-6 py-3 rounded-full text-sm font-bold shadow-2xl z-50 transition-all duration-300 ease-out";
            banner.textContent = "🔥 Streak Extended! Banked +45 Minutes Game Time.";
            document.body.appendChild(banner);
            
            setTimeout(() => {
                banner.classList.add('opacity-0');
                setTimeout(() => banner.remove(), 300);
            }, 3000);
        });

        window.onload = function () {
            init();
        };
    </script>
</body>
</html>
